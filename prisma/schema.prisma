// ════════════════════════════════════════════════════
//  Prisma Schema — Pharma Council Thailand
//  Database: SQLite (dev) → PostgreSQL/MySQL (prod)
// ════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Users ─────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  thaiId       String   @unique
  licenseId    String?  @unique
  organization String?
  university   String?
  phone        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]

  @@map("users")
}

// ─── Sessions ──────────────────────────────────────
model Session {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

// ─── Analytics ─────────────────────────────────────
model DailyVisitor {
  id    Int      @id @default(autoincrement())
  date  String   @unique // format: YYYY-MM-DD
  count Int      @default(0)

  @@map("daily_visitors")
}
